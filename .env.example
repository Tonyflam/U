# WhalePod — environment template
#
# Copy to `.env` (gitignored) for local dev. In production set as platform
# secrets (Fly.io / Vercel / Railway). NEVER commit a real `.env`.
#
# Format: KEY=value   (no quotes unless the value contains spaces)

# =============================================================================
# UNIVERSAL  (every service)
# =============================================================================
NODE_ENV=development              # development | test | staging | production
LOG_LEVEL=info                    # fatal | error | warn | info | debug | trace
SERVICE_NAME=bot                  # bot | miniapp | web | admin | ws-consumer

# =============================================================================
# POSTGRES  (bot, admin, ws-consumer, miniapp)
# =============================================================================
# Managed Postgres: Supabase, Neon, or RDS. Must support `gen_random_uuid()`
# (pgcrypto). Connection pooler URL is fine; we set `prepare: false` for
# pgbouncer compatibility.
DATABASE_URL=postgres://user:pass@host:5432/whalepod
DATABASE_SSL=require              # require | prefer | disable

# =============================================================================
# REDIS  (bot onboarding store, ws-consumer fan-out)
# =============================================================================
# Upstash REST (edge-friendly). https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# AWS KMS  (vault — encrypts user agent keys at rest)
# =============================================================================
# Symmetric CMK with kms:Encrypt / kms:Decrypt / kms:GenerateDataKey for the
# service principal. In prod, prefer IAM role over long-lived access keys.
AWS_REGION=us-east-1
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/REPLACE-ME
# Local-dev only:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# =============================================================================
# HYPERLIQUID  (sdk, ws-consumer, order router)
# =============================================================================
# BUILDER_ADDRESS receives builder fees. Every user approves it via
# approveBuilderFee in the miniapp onboarding flow.
# Cap = 10 bps = 100 tenths-of-a-bp. Default 5 bps = 50 tenths-of-a-bp.
HL_NETWORK=mainnet                # mainnet | testnet
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws
BUILDER_ADDRESS=0x0000000000000000000000000000000000000000
BUILDER_DEFAULT_FEE_TENTHS_BP=50

# =============================================================================
# TELEGRAM BOT  (apps/bot)
# =============================================================================
# Get a token from @BotFather:
#   /newbot → name, username → token
#   /setdomain → paste PUBLIC_MINIAPP_URL
#   /setmenubutton → "Open WhalePod" → PUBLIC_MINIAPP_URL
#   /setjoingroups → Disable    /setprivacy → Enable
# Webhook secret: `openssl rand -hex 32`
TELEGRAM_BOT_TOKEN=               # REPLACE — and never commit a real token
TELEGRAM_BOT_USERNAME=WhalePodBot # bot @handle without the @; used for /share deeplinks
TELEGRAM_WEBHOOK_SECRET=
BOT_MODE=webhook                  # webhook (prod) | polling (dev)
BOT_PORT=8080

# Mirror-intents stream consumer (each replica needs a unique name).
MIRROR_CONSUMER_NAME=bot-1
MIRROR_BATCH_SIZE=32

# Mark-price cache (HL `allMids`) refresh cadence in ms; also used to refresh
# the asset index.
HL_ASSET_REFRESH_MS=3600000

# Per-mirror risk caps enforced before submit. Keep conservative defaults.
RISK_MAX_SLIPPAGE_BPS=200
RISK_MAX_DAILY_NOTIONAL_USD=1000000
RISK_BLOCKED_COUNTRIES=            # comma-separated ISO-3166-1 alpha-2 codes
RISK_REQUIRE_KNOWN_GEO=false

# =============================================================================
# PUBLIC URLS
# =============================================================================
PUBLIC_APP_URL=https://whalepod.trade
PUBLIC_MINIAPP_URL=https://app.whalepod.trade
PUBLIC_API_URL=https://api.whalepod.trade

# =============================================================================
# ADMIN  (apps/admin)
# =============================================================================
# Comma-separated Telegram user IDs allowed to run /global_kill etc.
# Get your tg user id from @userinfobot. Two-person rule recommended.
ADMIN_OPERATOR_TG_IDS=            # e.g. 12345678,87654321

# =============================================================================
# WS-CONSUMER  (apps/ws-consumer)
# =============================================================================
WHALE_SEED_ADDRESSES=
WS_BACKOFF_MIN_MS=1000
WS_BACKOFF_MAX_MS=30000

# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
BETTER_STACK_TOKEN=

# =============================================================================
# MINIAPP  (apps/miniapp — Next.js).  NEXT_PUBLIC_* ships to the browser.
# =============================================================================
NEXT_PUBLIC_HL_NETWORK=mainnet
NEXT_PUBLIC_BUILDER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BOT_URL=https://t.me/WhalePodBot

# =============================================================================
# LANDING PAGE  (apps/web)
# =============================================================================
BOT_URL=https://t.me/WhalePodBot  # used at build time by apps/web/src/build.ts
